Sub SayHello(ByVal name As String)
    Console.WriteLine("Hello, " & name)
End Sub

Sub Increment(ByRef value As Integer)
    value = value + 1
End Sub

Sub GreetAndIncrement(ByVal name As String, ByRef value As Integer)
    SayHello(name)
    Increment(value)
End Sub

Sub Main()
    Dim x As Integer
    x = 10

    GreetAndIncrement("Valo", x)

    Console.WriteLine(x)
End Sub

