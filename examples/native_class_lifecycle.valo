Class Box
    Private value As Integer

    Public Sub Constructor(ByVal initial As Integer)
        value = initial
    End Sub

    Public Default Property Get Item() As Integer
        Return value
    End Property

    Public Sub Terminate()
        Console.WriteLine("terminated")
    End Sub
End Class

Sub Main()
    Dim box As Box
    Set box = New Box(10)
    Console.WriteLine(box)
    Set box = Nothing
End Sub
