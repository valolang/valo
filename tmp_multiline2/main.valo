Sub Main()
    Dim hexStr As String
    Dim opcodes() As Byte
    Dim i As Long
    hexStr = "AA" & _
             "BB" & _
             "CC"
    ReDim opcodes(0 To (Len(hexStr) \ 2) - 1)
    For i = 0 To UBound(opcodes)
        opcodes(i) = CByte("&H" & Mid$(hexStr, (i * 2) + 1, 2))
    Next i
    Console.WriteLine(opcodes(0))
End Sub
